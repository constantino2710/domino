# Backend (server.js) — copie para .env e preencha
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Porta do servidor
PORT=8080

# CLI do Supabase (migrations) via Docker
# Gere em: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Senha do banco definida ao criar o projeto
SUPABASE_DB_PASSWORD=
# Extraído do URL (xxxxx em https://xxxxx.supabase.co)
SUPABASE_PROJECT_REF=
